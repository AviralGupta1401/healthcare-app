generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(PATIENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor        Doctor?
  patient       Patient?
  notifications Notification[]
  calendarEvents CalendarEvent[]
}

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialization  String
  qualifications  String?
  slotDuration    Int      @default(30)
  consultationFee Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id])
  availability DoctorAvailability[]
  leaves       DoctorLeave[]
  appointments Appointment[]
  slots        SlotHold[]
}

model DoctorAvailability {
  id         String  @id @default(cuid())
  doctorId   String
  dayOfWeek  Int     // 0=Sunday, 1=Monday ... 6=Saturday
  startTime  String  // "09:00"
  endTime    String  // "17:00"
  isAvailable Boolean @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model DoctorLeave {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model Patient {
  id          String   @id @default(cuid())
  userId      String   @unique
  dateOfBirth DateTime?
  bloodGroup  String?
  allergies   String?

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  slotHolds    SlotHold[]
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  date            DateTime          @db.Date
  startTime       String            // "09:30"
  endTime         String            // "10:00"
  status          AppointmentStatus @default(SCHEDULED)
  symptoms        String?
  preVisitSummary Json?
  postVisitNotes  String?
  postVisitSummary Json?
  cancellationReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id])
  doctor      Doctor       @relation(fields: [doctorId], references: [id])
  medications Medication[]
  calendarEvents CalendarEvent[]

  @@unique([doctorId, date, startTime])
}

model SlotHold {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime @db.Date
  startTime String
  endTime   String
  patientId String
  expiresAt DateTime

  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([expiresAt])
}

model Medication {
  id               String   @id @default(cuid())
  appointmentId    String
  name             String
  dosage           String
  frequency        String   // "3 times a day", "once daily"
  duration         String   // "7 days"
  instructions     String?
  reminderEnabled  Boolean  @default(true)
  lastRemindedAt   DateTime?
  createdAt        DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Notification {
  id         String             @id @default(cuid())
  userId     String
  type       String             // "BOOKING_CONFIRMATION", "REMINDER", "CANCELLATION", "LEAVE_NOTICE", "MEDICATION_REMINDER"
  channel    NotificationChannel @default(EMAIL)
  subject    String
  body       String
  status     NotificationStatus  @default(PENDING)
  retryCount Int                @default(0)
  maxRetries Int                @default(5)
  nextRetryAt DateTime?
  sentAt     DateTime?
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([status, nextRetryAt])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  appointmentId String
  userId        String
  googleEventId String?
  eventType     String   // "PATIENT", "DOCTOR"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}
