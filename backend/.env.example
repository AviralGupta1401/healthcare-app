# Database
DATABASE_URL="postgresql://user:password@host:5432/healthcare?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# LLM (Groq or OpenAI)
# Groq API key (starts with gsk_) or OpenAI key (starts with sk-)
# Auto-detected: gsk_* → uses Groq API (llama-3.3-70b), sk-* → uses OpenAI (gpt-4o-mini)
OPENAI_API_KEY="gsk_your-groq-api-key"

# Email — SendGrid (production) or Mailpit (local dev with Docker)
# Leave empty for mock mode (logs instead of sending)
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
FROM_EMAIL="noreply@healthcare.app"

# Google Calendar OAuth 2.0
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:4000/api/calendar/oauth2callback"
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"

# Redis (for Bull queues)
REDIS_URL="redis://user:password@host:6379"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
